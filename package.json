{
    "name": "icon-creator",
    "version": "0.4.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --hot server/index.tsx",
        "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
        "start": "NODE_ENV=production bun server/index.tsx",
        "test": "vitest --config vitest.unit.config.ts",
        "test:run": "vitest run --config vitest.unit.config.ts",
        "test:ui": "vitest --ui --config vitest.unit.config.ts",
        "test:coverage": "vitest run --coverage --config vitest.unit.config.ts"
    },
    "engines": {
        "bun": ">=1.2.0"
    },
    "engineStrict": true,
    "dependencies": {
        "classnames": "^2.5.1",
        "react": "^19",
        "react-dom": "^19"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/bun": "latest",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "jsdom": "^26.1.0",
        "vitest": "^3.2.4",
        "@vitest/browser": "^3.2.4",
        "playwright": "^1.55.0",
        "@vitest/coverage-v8": "^3.2.4"
    }
}
