{
    "name": "icon-creator",
    "version": "0.8.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --hot server/index.tsx",
        "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.BUN_ENV='\"production\"' --env='BUN_PUBLIC_*'",
        "start": "BUN_ENV=production bun server/index.tsx",
        "test": "bun x vitest --config vitest.unit.config.ts",
        "test:run": "bun x vitest run --config vitest.unit.config.ts",
        "test:ui": "bun x vitest --ui --config vitest.unit.config.ts",
        "test:coverage": "bun x vitest run --coverage --config vitest.unit.config.ts",
        "clean": "rm -rf node_modules dist bun.lock"
    },
    "engines": {
        "bun": ">=1.2.0"
    },
    "engineStrict": true,
    "dependencies": {
        "classnames": "^2.5.1",
        "paper": "^0.12.18",
        "react": "^19",
        "react-dom": "^19",
        "version": "^0.1.2"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/bun": "latest",
        "@types/paper": "^0.12",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^5.0.2",
        "@vitest/browser": "^3.2.4",
        "@vitest/coverage-v8": "^3.2.4",
        "happy-dom": "^18.0.1",
        "jsdom": "^27.0.0",
        "playwright": "^1.55.0",
        "vite": "^7.1.5",
        "vitest": "^4.0.14"
    }
}
